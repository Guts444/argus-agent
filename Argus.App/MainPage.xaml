<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Argus.App.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Argus.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    RequestedTheme="Dark"
    Background="{StaticResource ArgusBackgroundBrush}"
    DataContext="{x:Bind ViewModel}"
    KeyDown="MainPage_OnKeyDown"
    IsTabStop="True"
    mc:Ignorable="d">

    <Page.Resources>
        <Storyboard x:Name="DashboardChatPulse">
            <DoubleAnimation
                Storyboard.TargetName="DashboardChatPulseGlow"
                Storyboard.TargetProperty="Opacity"
                From="0.24"
                To="0.92"
                Duration="0:0:1.7"
                AutoReverse="True"
                RepeatBehavior="Forever" />
        </Storyboard>
    </Page.Resources>

    <Grid x:Name="ShellRoot" ColumnSpacing="0" RowSpacing="0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="76" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="360" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="72" />
            <RowDefinition Height="*" />
            <RowDefinition Height="270" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="4" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,0,1,0">
            <Grid Padding="10,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Width="44" Height="44" CornerRadius="8" BorderBrush="{StaticResource ArgusBorderBrush}" BorderThickness="1" Background="#3310F7FF">
                    <Grid>
                        <Image Source="Assets/ArgusMark.png" Width="40" Height="40" Stretch="Uniform" />
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,26,0,0" Spacing="8">
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowDashboardCommand}" ToolTipService.ToolTip="Dashboard">
                        <FontIcon Glyph="&#xE80F;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowGraphCommand}" ToolTipService.ToolTip="Graph">
                        <FontIcon Glyph="&#xE774;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowProjectsCommand}" ToolTipService.ToolTip="Projects">
                        <FontIcon Glyph="&#xE8F1;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowIdeasCommand}" ToolTipService.ToolTip="Ideas">
                        <FontIcon Glyph="&#xEA80;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowTasksCommand}" ToolTipService.ToolTip="Tasks">
                        <FontIcon Glyph="&#xE73E;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowConversationsCommand}" ToolTipService.ToolTip="Messaging">
                        <FontIcon Glyph="&#xE8F2;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowMemoriesCommand}" ToolTipService.ToolTip="Memories">
                        <FontIcon Glyph="&#xE8AB;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowSkillsCommand}" ToolTipService.ToolTip="Skills">
                        <FontIcon Glyph="&#xE950;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowAuditsCommand}" ToolTipService.ToolTip="Tool Audits">
                        <FontIcon Glyph="&#xE9F9;" FontSize="17" />
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowSettingsCommand}" ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;" FontSize="17" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Spacing="8">
                    <Border Width="8" Height="8" CornerRadius="4" Background="{StaticResource ArgusAccentBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="LOCAL" FontSize="9" Foreground="{StaticResource ArgusMutedTextBrush}" FontFamily="Cascadia Code" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" Padding="18,12" Background="#AA080D18" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,0,0,1"
            Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=!Dashboard}">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox x:Name="GlobalSearchBox" PlaceholderText="Search nodes, memories, projects, decisions" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1" Command="{Binding SearchCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE721;" FontSize="14" />
                        <TextBlock Text="Search" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Command="{Binding NewNodeCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="New Node" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="3" Command="{Binding CreateEdgeCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8F4;" FontSize="14" />
                        <TextBlock Text="New Edge" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="4" Command="{Binding AskAgentCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8BD;" FontSize="14" />
                        <TextBlock Text="Ask Argus" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" Grid.RowSpan="3" Padding="14,16,18,14"
            Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Dashboard}">
            <controls:CyberBackground IsHitTestVisible="False" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid MinHeight="680" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2">
                            <TextBlock Text="COMMAND CENTER" Style="{StaticResource PanelTitleStyle}" FontSize="24" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Button Command="{Binding NewNodeCommand}" ToolTipService.ToolTip="New node">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                            </Button>
                            <Button Command="{Binding OpenCommandPaletteCommand}" ToolTipService.ToolTip="Command palette">
                                <FontIcon Glyph="&#xE756;" FontSize="14" />
                            </Button>
                            <Button ToolTipService.ToolTip="Edit widgets">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                <Button.Flyout>
                                    <Flyout Placement="BottomEdgeAlignedRight">
                                        <StackPanel Spacing="10" MinWidth="180">
                                            <TextBlock Text="Manage Widgets" FontWeight="Bold" Style="{StaticResource MetaTextStyle}" Margin="0,0,0,4" />
                                            <CheckBox Content="System Status" IsChecked="{Binding ShowSystemStatusWidget, Mode=TwoWay}" />
                                            <CheckBox Content="Active Projects" IsChecked="{Binding ShowProjectsWidget, Mode=TwoWay}" />
                                            <CheckBox Content="Market" IsChecked="{Binding ShowMarketWidget, Mode=TwoWay}" />
                                            <CheckBox Content="Intel Feed" IsChecked="{Binding ShowNewsWidget, Mode=TwoWay}" />
                                            <CheckBox Content="Soccer Scoreboard" IsChecked="{Binding ShowSportsWidget, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Column0Width}" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="{Binding Column2Width}" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="12">
                            <Border Style="{StaticResource DashboardWidgetStyle}" Visibility="{Binding ShowSystemStatusWidget, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Spacing="12">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="#FF00FF88" VerticalAlignment="Center" />
                                        <TextBlock Text="SYSTEM STATUS" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                    </StackPanel>
                                    <Grid ColumnSpacing="12" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="CPU" Style="{StaticResource MetaTextStyle}" />
                                            <TextBlock Text="{Binding DashboardWidgets.CpuText}" Style="{StaticResource MetricTextStyle}" Foreground="{StaticResource ArgusAccentBrush}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="RAM" Style="{StaticResource MetaTextStyle}" />
                                            <TextBlock Text="{Binding DashboardWidgets.RamPercentText}" Style="{StaticResource MetricTextStyle}" Foreground="{StaticResource ArgusMagentaBrush}" />
                                            <TextBlock Text="{Binding DashboardWidgets.RamText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="NETWORK" Style="{StaticResource MetaTextStyle}" />
                                            <TextBlock Text="{Binding DashboardWidgets.NetDownText}" Foreground="{StaticResource ArgusAccentBrush}" FontSize="12" FontFamily="Cascadia Code" />
                                            <TextBlock Text="{Binding DashboardWidgets.NetUpText}" Foreground="{StaticResource ArgusMagentaBrush}" FontSize="12" FontFamily="Cascadia Code" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="1" Grid.Column="1">
                                            <TextBlock Text="DISK / GPU" Style="{StaticResource MetaTextStyle}" />
                                            <TextBlock Text="{Binding DashboardWidgets.DiskText}" Foreground="{StaticResource ArgusAmberBrush}" FontSize="12" FontFamily="Cascadia Code" />
                                            <TextBlock Text="{Binding DashboardWidgets.GpuText}" Foreground="#FF00FF88" FontSize="12" FontFamily="Cascadia Code" />
                                        </StackPanel>
                                        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="12">
                                            <TextBlock Text="{Binding DashboardWidgets.UptimeText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" />
                                            <TextBlock Text="{Binding DashboardWidgets.ProcessText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- PROJECT COCKPIT -->
                            <Border Style="{StaticResource DashboardWidgetStyle}" Visibility="{Binding ShowProjectsWidget, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid RowSpacing="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Header with stats -->
                                    <StackPanel Spacing="4">
                                        <Grid>
                                            <TextBlock Text="PROJECT COCKPIT" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6"
                                                        Visibility="{Binding ProjectCockpit, Converter={StaticResource NullToVisibilityConverter}}">
                                                <Border Padding="6,2" CornerRadius="4" Background="#2220EAF2">
                                                    <TextBlock Text="{Binding ProjectCockpit.TotalOpenTasksText}"
                                                               FontFamily="Cascadia Code" FontSize="10" Foreground="{StaticResource ArgusAccentBrush}" />
                                                </Border>
                                                <Border Padding="6,2" CornerRadius="4" Background="#22FFAA00"
                                                        Visibility="{Binding ProjectCockpit.HasGlobalBlockers, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding ProjectCockpit.TotalBlockersText}"
                                                               FontFamily="Cascadia Code" FontSize="10" Foreground="{StaticResource ArgusAmberBrush}" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Blocker alerts -->
                                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ProjectCockpit.GlobalBlockers}"
                                                  Visibility="{Binding ProjectCockpit.HasGlobalBlockers, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,5" Margin="0,2" CornerRadius="4"
                                                        Background="#22FFAA00" BorderBrush="#44FFAA00" BorderThickness="1">
                                                    <TextBlock Text="{Binding}" FontSize="11" Foreground="{StaticResource ArgusAmberBrush}"
                                                               TextWrapping="WrapWholeWords" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Project cards -->
                                    <ListView Grid.Row="2" ItemsSource="{Binding ProjectCockpitCards}"
                                              Style="{StaticResource DashboardListViewStyle}" MaxHeight="360">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="8,6" Margin="0,4" CornerRadius="6"
                                                        Background="#110A1222" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                                                    <StackPanel Spacing="6">
                                                        <!-- Project name + health badge -->
                                                        <Grid>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding ProjectNode.Title}" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource ArgusTextBrush}" FontSize="12" />
                                                                <TextBlock Text="{Binding ProjectNode.Summary}" Style="{StaticResource MetaTextStyle}"
                                                                           FontSize="10" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                            </StackPanel>
                                                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                    Padding="5,2" CornerRadius="3"
                                                                    Background="{Binding HasRepoWarning, Converter={StaticResource WarningBackgroundConverter}}"
                                                                    Visibility="{Binding HasRepoHealth, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding RepoHealthDisplay}" FontFamily="Cascadia Code" FontSize="9"
                                                                           Foreground="{Binding HasRepoWarning, Converter={StaticResource WarningForegroundConverter}}" />
                                                            </Border>
                                                        </Grid>

                                                        <!-- Count badges -->
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <Border Padding="5,1" CornerRadius="3" Background="#1810F7FF">
                                                                <TextBlock Text="{Binding OpenTaskCountText}"
                                                                           FontSize="10" Foreground="{StaticResource ArgusAccentBrush}" />
                                                            </Border>
                                                            <Border Padding="5,1" CornerRadius="3" Background="#18AA60FF">
                                                                <TextBlock Text="{Binding DecisionCountText}"
                                                                           FontSize="10" Foreground="{StaticResource ArgusVioletBrush}" />
                                                            </Border>
                                                            <Border Padding="5,1" CornerRadius="3" Background="#22FFAA00"
                                                                    Visibility="{Binding HasBlockers, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <TextBlock Text="{Binding BlockerCountText}"
                                                                           FontSize="10" Foreground="{StaticResource ArgusAmberBrush}" />
                                                            </Border>
                                                        </StackPanel>

                                                        <!-- Next action (first one) -->
                                                        <TextBlock Text="{Binding FirstNextAction}" FontSize="10"
                                                                   Foreground="{StaticResource ArgusMutedTextBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxLines="1" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <!-- Next actions summary -->
                                    <Border Grid.Row="2" Background="Transparent" VerticalAlignment="Bottom"
                                            Visibility="{Binding ProjectCockpit.HasGlobalNextActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel Spacing="3">
                                            <TextBlock Text="NEXT ACTIONS" FontFamily="Cascadia Code" FontSize="9"
                                                       Foreground="{StaticResource ArgusAccentBrush}" Margin="0,6,0,0" />
                                            <ItemsControl ItemsSource="{Binding ProjectCockpit.GlobalNextActions}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock FontSize="10" Foreground="{StaticResource ArgusMutedTextBrush}"
                                                                   TextWrapping="WrapWholeWords" Margin="0,1"
                                                                   Text="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Grid Grid.Column="1" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Grid.Row="0">
                                <controls:ArgusCoreControl Width="360" Height="360" HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False" />
                            </Grid>

                            <Border Grid.Row="1" MaxWidth="720" HorizontalAlignment="Stretch" Loaded="DashboardChatPulse_OnLoaded" Margin="0,0,0,16">
                                <Grid>
                                    <Border x:Name="DashboardChatPulseGlow" CornerRadius="30" BorderBrush="#AA36F7FF" BorderThickness="1" Opacity="0.32" />
                                    <Border Margin="1" Padding="14" CornerRadius="29" Background="#33020712" BorderBrush="#6636F7FF" BorderThickness="1">
                                        <Grid RowSpacing="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <ListView x:Name="DashboardChatList" ItemsSource="{Binding ChatMessages}" SelectionMode="None" MaxHeight="300" Background="Transparent" BorderBrush="Transparent">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,3">
                                                            <!-- Standard message -->
                                                            <StackPanel Visibility="{Binding Role, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=message}">
                                                                <TextBlock Text="{Binding Role}" FontSize="9" Foreground="{StaticResource ArgusMutedTextBrush}" FontFamily="Cascadia Code" />
                                                                <TextBlock Text="{Binding Content}" TextWrapping="WrapWholeWords" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" />
                                                            </StackPanel>

                                                            <!-- Thinking process -->
                                                            <StackPanel Visibility="{Binding Role, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=thinking}">
                                                                <Expander HorizontalAlignment="Stretch" Margin="0,3" ExpandDirection="Down" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                                                    <Expander.Header>
                                                                        <Grid ColumnSpacing="8">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <ProgressRing IsActive="{Binding Content, Converter={StaticResource ThinkingActiveConverter}}"
                                                                                          Visibility="{Binding Content, Converter={StaticResource ThinkingActiveVisibilityConverter}}"
                                                                                          Width="12" Height="12" VerticalAlignment="Center" />
                                                                            <TextBlock Grid.Column="1" Text="{Binding Content, Converter={StaticResource ThinkingHeaderConverter}}"
                                                                                       FontWeight="SemiBold" FontSize="10" Foreground="{StaticResource ArgusMutedTextBrush}" VerticalAlignment="Center" />
                                                                        </Grid>
                                                                    </Expander.Header>
                                                                    <TextBlock Text="{Binding Content, Converter={StaticResource ThinkingBodyConverter}}"
                                                                               TextWrapping="Wrap" FontSize="10" Foreground="{StaticResource ArgusMutedTextBrush}" Padding="6,3" />
                                                                </Expander>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                            <Grid Grid.Row="1" ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="DashboardChatInputBox" PlaceholderText="Talk to Argus..." Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" KeyDown="ChatInputBox_OnKeyDown" />
                                                <Button Grid.Column="1" Command="{Binding SendChatCommand}" ToolTipService.ToolTip="Send">
                                                    <FontIcon Glyph="&#xE725;" FontSize="15" />
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="2" Spacing="12">
                            <Border Style="{StaticResource DashboardWidgetStyle}" Visibility="{Binding ShowMarketWidget, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="MARKET" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                            <Button Command="{Binding DashboardWidgets.RefreshStocksCommand}" FontSize="10" Padding="6,2" Content="SYNC" />
                                            <Button FontSize="10" Padding="6,2" ToolTipService.ToolTip="Edit stocks">
                                                <FontIcon Glyph="&#xE713;" FontSize="11" />
                                                <Button.Flyout>
                                                    <Flyout Placement="LeftEdgeAlignedTop">
                                                        <StackPanel Width="200" Spacing="8">
                                                            <TextBlock Text="EDIT STOCKS" Style="{StaticResource PanelTitleStyle}" FontSize="12" />
                                                            <TextBox Header="Symbols (comma separated)" Text="{Binding DashboardWidgets.StocksConfigInput, Mode=TwoWay}" PlaceholderText="AAPL, MSFT, GOOGL" />
                                                            <Button Content="Save" Command="{Binding DashboardWidgets.SaveStocksConfigCommand}" HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <ListView Grid.Row="1" ItemsSource="{Binding DashboardWidgets.StockQuotes}" Style="{StaticResource DashboardListViewStyle}" MaxHeight="150">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="10" Margin="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="62" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Symbol}" FontWeight="Bold" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" />
                                                        <TextBlock Text="{Binding CompanyName}" Style="{StaticResource MetaTextStyle}" FontSize="9" MaxLines="1" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding CurrentPrice}" Foreground="{StaticResource ArgusTextBrush}" FontSize="13" FontFamily="Cascadia Code" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="2" Text="{Binding ChangePercent}" Foreground="{StaticResource ArgusAccentBrush}" FontSize="12" FontFamily="Cascadia Code" VerticalAlignment="Center" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <TextBlock Grid.Row="2" Text="{Binding DashboardWidgets.StocksStatusText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" FontSize="10" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DashboardWidgetStyle}" Visibility="{Binding ShowNewsWidget, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="INTEL FEED" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                                        <Button Content="ALL" FontSize="10" Padding="8,2" Command="{Binding DashboardWidgets.SetNewsCategoryCommand}" CommandParameter="all"
                                                Background="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveBrushConverter}, ConverterParameter=all}"
                                                Foreground="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveForegroundConverter}, ConverterParameter=all}" />
                                        <Button Content="TECH" FontSize="10" Padding="8,2" Command="{Binding DashboardWidgets.SetNewsCategoryCommand}" CommandParameter="tech"
                                                Background="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveBrushConverter}, ConverterParameter=tech}"
                                                Foreground="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveForegroundConverter}, ConverterParameter=tech}" />
                                        <Button Content="AI" FontSize="10" Padding="8,2" Command="{Binding DashboardWidgets.SetNewsCategoryCommand}" CommandParameter="ai"
                                                Background="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveBrushConverter}, ConverterParameter=ai}"
                                                Foreground="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveForegroundConverter}, ConverterParameter=ai}" />
                                        <Button Content="GAMES" FontSize="10" Padding="8,2" Command="{Binding DashboardWidgets.SetNewsCategoryCommand}" CommandParameter="gaming"
                                                Background="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveBrushConverter}, ConverterParameter=gaming}"
                                                Foreground="{Binding DashboardWidgets.NewsCategory, Converter={StaticResource CategoryActiveForegroundConverter}, ConverterParameter=gaming}" />
                                    </StackPanel>
                                    <ListView Grid.Row="2" ItemsSource="{Binding DashboardWidgets.NewsArticles}" Style="{StaticResource DashboardListViewStyle}" MaxHeight="235">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,5">
                                                    <TextBlock Text="{Binding Source}" FontSize="9" Foreground="{StaticResource ArgusMagentaBrush}" FontFamily="Cascadia Code" />
                                                    <TextBlock Text="{Binding Title}" TextWrapping="WrapWholeWords" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <TextBlock Grid.Row="3" Text="{Binding DashboardWidgets.NewsStatusText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" FontSize="10" />
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource DashboardWidgetStyle}" Visibility="{Binding ShowSportsWidget, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <TextBlock Text="SOCCER" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="6">
                                            <Button Command="{Binding DashboardWidgets.RefreshSportsCommand}" FontSize="10" Padding="6,2" Content="SYNC" />
                                            <Button FontSize="10" Padding="6,2" ToolTipService.ToolTip="Edit soccer feed">
                                                <FontIcon Glyph="&#xE713;" FontSize="11" />
                                                <Button.Flyout>
                                                    <Flyout Placement="LeftEdgeAlignedTop">
                                                        <StackPanel Width="220" Spacing="8">
                                                            <TextBlock Text="EDIT SOCCER" Style="{StaticResource PanelTitleStyle}" FontSize="12" />
                                                            <ComboBox Header="League / Competition" SelectedItem="{Binding DashboardWidgets.SelectedSportsLeague, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                                                <x:String>eng.1 (English Premier League)</x:String>
                                                                <x:String>esp.1 (Spanish La Liga)</x:String>
                                                                <x:String>ita.1 (Italian Serie A)</x:String>
                                                                <x:String>ger.1 (German Bundesliga)</x:String>
                                                                <x:String>fra.1 (French Ligue 1)</x:String>
                                                                <x:String>usa.1 (MLS)</x:String>
                                                                <x:String>uefa.champions (Champions League)</x:String>
                                                            </ComboBox>
                                                            <TextBox Header="Teams (comma separated)" Text="{Binding DashboardWidgets.SportsTeamsInput, Mode=TwoWay}" PlaceholderText="e.g. Manchester United, Chelsea" />
                                                            <Button Content="Save" Command="{Binding DashboardWidgets.SaveSportsConfigCommand}" HorizontalAlignment="Right" />
                                                        </StackPanel>
                                                    </Flyout>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <ListView Grid.Row="1" ItemsSource="{Binding DashboardWidgets.SportScores}" Style="{StaticResource DashboardListViewStyle}" MaxHeight="115">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,5" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding HomeTeam}" HorizontalAlignment="Right" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="1">
                                                        <TextBlock FontSize="13" FontWeight="Bold" Foreground="{StaticResource ArgusTextBrush}" FontFamily="Cascadia Code" HorizontalAlignment="Center">
                                                            <Run Text="{Binding HomeScore}" /><Run Text="-" /><Run Text="{Binding AwayScore}" />
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Status}" Style="{StaticResource MetaTextStyle}" FontSize="9" HorizontalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding AwayTeam}" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                    <TextBlock Grid.Row="2" Text="{Binding DashboardWidgets.SportsStatusText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" FontSize="10" />
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Column="1" Grid.Row="1" Padding="18">
            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Graph}">
                <controls:GraphCanvasControl x:Name="GraphSurface" ViewModel="{Binding}" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0">
                    <Border Padding="10,7" CornerRadius="6" Background="#B20B1220" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding GraphFilterLabel}" Foreground="{StaticResource ArgusMutedTextBrush}" />
                    </Border>
                    <Button Command="{Binding ClearGraphFilterCommand}">
                        <FontIcon Glyph="&#xE711;" />
                    </Button>
                    <Button Click="FitGraph_OnClick">
                        <FontIcon Glyph="&#xE9A6;" />
                    </Button>
                    <Button Click="ResetGraph_OnClick">
                        <FontIcon Glyph="&#xE72C;" />
                    </Button>
                    <Button Click="ClusterGraph_OnClick">
                        <FontIcon Glyph="&#xE8FD;" />
                    </Button>
                    <Button>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE7B3;" FontSize="14" />
                            <TextBlock Text="Views" />
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Go to View 1" Click="GoToView1_OnClick">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE12F;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Save current as View 1" Click="SaveView1_OnClick">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74E;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Go to View 2" Click="GoToView2_OnClick">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE12F;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Save current as View 2" Click="SaveView2_OnClick">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74E;" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                    <Button Command="{Binding RefreshGraphCommand}">
                        <FontIcon Glyph="&#xE72C;" />
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Memories}">
                <Border Padding="16" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="MEMORY DEBUGGER" Style="{StaticResource PanelTitleStyle}" FontSize="18" />
                                <TextBlock Text="{Binding MemoryDebuggerStatusText}" Style="{StaticResource MetaTextStyle}" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                            <ProgressRing Grid.Column="1" Width="20" Height="20" IsActive="{Binding IsMemoryDebuggerBusy}"
                                          Visibility="{Binding IsMemoryDebuggerBusy, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                        <Grid Grid.Row="1" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="Ask a test question, e.g. What did we decide about local-first storage?"
                                     Text="{Binding MemorySearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Command="{Binding SearchMemoriesCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE9D9;" FontSize="14" />
                                    <TextBlock Text="Evaluate Recall" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Content="Recent" Command="{Binding ShowRecentMemoriesCommand}" />
                        </Grid>
                        <ListView Grid.Row="2" ItemsSource="{Binding MemoryRecallResults}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8" CornerRadius="8" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Padding="8" CornerRadius="6" Background="#2210F7FF" BorderBrush="{StaticResource ArgusAccentBrush}" BorderThickness="1"
                                                    VerticalAlignment="Top">
                                                <StackPanel Spacing="3">
                                                    <TextBlock Text="{Binding ScoreText}" Foreground="{StaticResource ArgusAccentBrush}" FontSize="18"
                                                               FontWeight="SemiBold" FontFamily="Cascadia Code" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding MethodText}" Foreground="{StaticResource ArgusMutedTextBrush}" FontSize="8"
                                                               FontFamily="Cascadia Code" TextAlignment="Center" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="6">
                                                <TextBlock Text="{Binding Text}" TextWrapping="WrapWholeWords" Foreground="{StaticResource ArgusTextBrush}" />
                                                <TextBlock Text="{Binding MetadataText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" FontSize="10" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Explanation}" Foreground="{StaticResource ArgusAccentBrush}" FontSize="11" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{Binding ComponentScoresText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" FontSize="9" TextWrapping="Wrap" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Button Content="Useful"
                                                            Command="{Binding ViewModel.MarkMemoryUsefulCommand, ElementName=RootPage}"
                                                            CommandParameter="{Binding}" />
                                                    <Button Content="Not relevant"
                                                            Command="{Binding ViewModel.MarkMemoryNotRelevantCommand, ElementName=RootPage}"
                                                            CommandParameter="{Binding}" />
                                                    <TextBlock Text="{Binding FeedbackText}" Style="{StaticResource MetaTextStyle}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- Empty state: no memory results -->
                        <TextBlock Grid.Row="2"
                                   Text="Enter a query above to evaluate memory recall. Results show scored, explainable matches from your local database."
                                   Style="{StaticResource MetaTextStyle}"
                                   Foreground="{StaticResource ArgusMutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   Visibility="{Binding HasMemoryResults, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=!}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Conversations}">
                <Border Padding="16" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                    <Grid RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox PlaceholderText="Search conversations" Text="{Binding ConversationSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Command="{Binding SearchConversationsCommand}">
                                <FontIcon Glyph="&#xE721;" />
                            </Button>
                        </Grid>
                        <!-- Search results -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding ConversationSearchResults}"
                                  Visibility="{Binding HasConversationSearchResults, Converter={StaticResource BoolToVisibilityConverter}}"
                                  SelectionMode="Single">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,0,0,8" CornerRadius="8" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding Role}" FontWeight="SemiBold" Foreground="{StaticResource ArgusAccentBrush}" />
                                                <TextBlock Text="{Binding ConversationTitle}" Style="{StaticResource MetaTextStyle}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Snippet}" Foreground="{StaticResource ArgusTextBrush}" TextWrapping="Wrap" MaxHeight="80" />
                                            <TextBlock Text="{Binding MessageCreatedAt, Converter={StaticResource DateTimeOffsetToStringConverter}}" Style="{StaticResource MetaTextStyle}" FontSize="10" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- Regular conversation list -->
                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Conversations}"
                                  Visibility="{Binding HasConversationSearchResults, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=!}"
                                  SelectionMode="Single"
                                  SelectedItem="{Binding SelectedConversation, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="10" Margin="0,0,0,8" CornerRadius="8" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource ArgusTextBrush}" />
                                            <TextBlock Text="{Binding UpdatedAt}" Style="{StaticResource MetaTextStyle}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- Empty state: no conversations -->
                        <TextBlock Grid.Row="1"
                                   Text="No conversations yet. Start a chat from the dashboard or Telegram."
                                   Style="{StaticResource MetaTextStyle}"
                                   Foreground="{StaticResource ArgusMutedTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextWrapping="WrapWholeWords"
                                   Visibility="{Binding HasConversations, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=!}" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Skills}">
                <Border Padding="16" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Skills" Style="{StaticResource PanelTitleStyle}" />
                        <Border Padding="14" CornerRadius="8" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1" Margin="0,10,0,0">
                            <StackPanel Spacing="10">
                                <ToggleSwitch Header="Auto Web Search" IsOn="{Binding IsWebSearchEnabled, Mode=TwoWay}" OffContent="Disabled" OnContent="Enabled" />
                                <TextBlock Text="When enabled, the Argus Agent will automatically query a local SearXNG docker instance to retrieve live web information if your prompt requires external context." Style="{StaticResource MetaTextStyle}" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Images and Notes coming soon." Style="{StaticResource MetaTextStyle}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Audits}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Spacing="10" Margin="0,0,16,10">
                    <TextBlock Text="TOOL EXECUTION AUDITS" Style="{StaticResource PanelTitleStyle}" FontSize="20" />
                    <Grid ColumnSpacing="10" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Search Tool Name..." Text="{Binding AuditFilterToolName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" Header="Risk" ItemsSource="{Binding AuditRiskFilterOptions}" SelectedItem="{Binding AuditFilterRiskLevel, Mode=TwoWay}" MinWidth="100" />
                        <ComboBox Grid.Column="2" Header="Approval" ItemsSource="{Binding AuditApprovalFilterOptions}" SelectedItem="{Binding AuditFilterApprovalStatus, Mode=TwoWay}" MinWidth="110" />
                        <ComboBox Grid.Column="3" Header="Outcome" ItemsSource="{Binding AuditOutcomeFilterOptions}" SelectedItem="{Binding AuditFilterOutcome, Mode=TwoWay}" MinWidth="110" />
                        <CheckBox Grid.Column="4" Content="Incomplete only" IsChecked="{Binding AuditFilterOnlyIncomplete, Mode=TwoWay}" VerticalAlignment="Bottom" Margin="0,0,0,4" />
                    </Grid>
                </StackPanel>

                <ListView Grid.Column="0" Grid.Row="1" ItemsSource="{Binding AuditRecords}" SelectedItem="{Binding SelectedAuditRecord, Mode=TwoWay}" SelectionMode="Single" Margin="0,0,16,0">
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="TIMESTAMP" Style="{StaticResource MetaTextStyle}" FontWeight="Bold" />
                                <TextBlock Grid.Column="1" Text="TOOL NAME" Style="{StaticResource MetaTextStyle}" FontWeight="Bold" />
                                <TextBlock Grid.Column="2" Text="RISK" Style="{StaticResource MetaTextStyle}" FontWeight="Bold" />
                                <TextBlock Grid.Column="3" Text="OUTCOME" Style="{StaticResource MetaTextStyle}" FontWeight="Bold" />
                                <TextBlock Grid.Column="4" Text="DURATION" Style="{StaticResource MetaTextStyle}" FontWeight="Bold" HorizontalAlignment="Right" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="110" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding StartedAt, Converter={StaticResource DateTimeOffsetToStringConverter}}" VerticalAlignment="Center" FontSize="11" Style="{StaticResource MetaTextStyle}" />
                                <TextBlock Grid.Column="1" Text="{Binding ToolName}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12" />
                                <TextBlock Grid.Column="2" Text="{Binding RiskLevel}" VerticalAlignment="Center" FontSize="11" Style="{StaticResource MetaTextStyle}" />
                                <Border Grid.Column="3" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Background="{Binding Outcome, Converter={StaticResource OutcomeToBrushConverter}}">
                                    <TextBlock Text="{Binding Outcome}" FontSize="10" FontWeight="Bold" Foreground="White" />
                                </Border>
                                <TextBlock Grid.Column="4" Text="{Binding DurationMilliseconds, Converter={StaticResource DurationFormatConverter}}" VerticalAlignment="Center" FontSize="11" HorizontalAlignment="Right" Style="{StaticResource MetaTextStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Padding="14" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <ScrollViewer Grid.Row="0" Margin="0,0,0,10">
                            <StackPanel Spacing="12">
                                <TextBlock Text="AUDIT RECORD DETAILS" Style="{StaticResource PanelTitleStyle}" FontSize="16" />
                                <StackPanel Visibility="{Binding SelectedAuditRecord, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="Execution ID" Style="{StaticResource MetaTextStyle}" />
                                    <TextBox Text="{Binding SelectedAuditRecord.ExecutionId}" IsReadOnly="True" FontSize="11" FontFamily="Cascadia Code" />
                                    
                                    <TextBlock Text="Agent Run ID" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding SelectedAuditRecord.AgentRunId}" IsReadOnly="True" FontSize="11" FontFamily="Cascadia Code" />
                                    
                                    <TextBlock Text="Conversation ID" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding SelectedAuditRecord.ConversationId}" IsReadOnly="True" FontSize="11" FontFamily="Cascadia Code" />

                                    <TextBlock Text="Approval Status" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding SelectedAuditRecord.ApprovalStatus}" IsReadOnly="True" FontSize="12" />

                                    <TextBlock Text="Arguments Summary" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding SelectedAuditRecord.ArgumentsSummary}" IsReadOnly="True" TextWrapping="Wrap" MaxHeight="100" FontSize="11" FontFamily="Cascadia Code" />
                                    
                                    <TextBlock Text="Result Summary" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                    <TextBox Text="{Binding SelectedAuditRecord.ResultSummary}" IsReadOnly="True" TextWrapping="Wrap" MaxHeight="100" FontSize="11" FontFamily="Cascadia Code" />

                                    <TextBlock Text="Error" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" Visibility="{Binding SelectedAuditRecord.Error, Converter={StaticResource NullToVisibilityConverter}}" />
                                    <TextBox Text="{Binding SelectedAuditRecord.Error}" IsReadOnly="True" TextWrapping="Wrap" MaxHeight="80" FontSize="11" Foreground="#FF6B6B" Visibility="{Binding SelectedAuditRecord.Error, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>
                                <TextBlock Text="Select an audit record to view execution details, arguments, and outcomes." Style="{StaticResource MetaTextStyle}" TextWrapping="WrapWholeWords"
                                           Visibility="{Binding SelectedAuditRecord, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=!}" />
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="1" Spacing="10" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                            <TextBlock Text="LOG RETENTION" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                            <TextBlock Text="Durable audits are preserved locally. You can prune old entries to manage database size." Style="{StaticResource MetaTextStyle}" TextWrapping="WrapWholeWords" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Content="Prune >30 Days" Command="{Binding PruneAuditsCommand}" />
                                <Button Content="Clear All Logs" Command="{Binding ClearAllAuditsCommand}" Background="#33FF4F5A" Foreground="#FFFF4F5A" BorderBrush="#88FF4F5A" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Settings}">
                <ScrollViewer>
                    <StackPanel Spacing="14" MaxWidth="600">
                        <TextBlock Text="LLM CONNECTION" Style="{StaticResource PanelTitleStyle}" FontSize="18" />
                        <Border Padding="14" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBlock Text="LLM service" Style="{StaticResource MetaTextStyle}" />
                                <ComboBox ItemsSource="{Binding ProviderProfiles}" SelectedItem="{Binding SelectedProvider, Mode=TwoWay}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock Text="Model" Style="{StaticResource MetaTextStyle}" Margin="0,8,0,0" />
                                <ComboBox ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding SelectedModel, Mode=TwoWay}" />
                                <TextBlock Text="{Binding ProviderAuthenticationHelpText}" Style="{StaticResource MetaTextStyle}"
                                           Margin="0,6,0,0" TextWrapping="WrapWholeWords" />
                                <StackPanel Visibility="{Binding IsApiKeyRequired, Converter={StaticResource BoolToVisibilityConverter}}" Spacing="4" Margin="0,8,0,0">
                                    <TextBlock Text="API Key" Style="{StaticResource MetaTextStyle}" />
                                    <PasswordBox x:Name="ApiKeyPasswordBox" PlaceholderText="{Binding ApiKeyPlaceholder}" PasswordChanged="ApiKeyBox_OnPasswordChanged" />
                                </StackPanel>
                                <StackPanel Visibility="{Binding IsOpenAiCodexProvider, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                    <Button Content="Sign in with ChatGPT" Command="{Binding SignInOpenAiCodexCommand}" />
                                    <Button Content="Sign out" Command="{Binding SignOutOpenAiCodexCommand}" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                                    <Button Command="{Binding SaveProviderSettingsCommand}">Save LLM Settings</Button>
                                    <Button Command="{Binding TestSelectedProviderCommand}">Test Connection</Button>
                                    <Button Command="{Binding RefreshProviderModelsCommand}">Refresh Models</Button>
                                </StackPanel>
                                <TextBlock Text="{Binding SettingsStatus}" Style="{StaticResource MetaTextStyle}" Margin="0,6,0,0" TextWrapping="WrapWholeWords" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="PROJECTS" Style="{StaticResource PanelTitleStyle}" FontSize="18" Margin="0,12,0,0" />
                        <Border Padding="14" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="8">
                                <TextBox Header="Projects Directory" PlaceholderText="Choose a folder containing your projects" Text="{Binding ProjectsRootPath, Mode=TwoWay}" />
                                <Button Command="{Binding ScanProjectsCommand}" HorizontalAlignment="Left">Scan Projects</Button>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="TELEGRAM GATEWAY" Style="{StaticResource PanelTitleStyle}" FontSize="18" Margin="0,12,0,0" />
                        <Border Padding="14" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ToggleSwitch Header="Gateway" IsOn="{Binding TelegramBotEnabled, Mode=TwoWay}" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                        <Border Width="8" Height="8" CornerRadius="4" Background="{Binding TelegramGatewayColorBrush}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding TelegramGatewayStatusDisplayText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" />
                                    </StackPanel>
                                </Grid>
                                <PasswordBox x:Name="TelegramTokenBox" Header="Bot Token" PlaceholderText="{Binding TelegramTokenPlaceholder}" PasswordChanged="TelegramTokenBox_OnPasswordChanged" />
                                <TextBox Header="Allowed User IDs" PlaceholderText="comma-separated Telegram user IDs" Text="{Binding TelegramAllowedUserIds, Mode=TwoWay}" />
                                <ToggleSwitch Header="Webhook Mode" IsOn="{Binding TelegramUseWebhook, Mode=TwoWay}" />
                                <TextBox Header="Webhook URL" PlaceholderText="https://example.com/telegram" Text="{Binding TelegramWebhookUrl, Mode=TwoWay}" />
                                <TextBox Header="Webhook Port" Text="{Binding TelegramWebhookPort, Mode=TwoWay}" />
                                <ToggleSwitch Header="Show Agent Thinking in Telegram" IsOn="{Binding ShowThinkingInTelegram, Mode=TwoWay}" />
                                <ToggleSwitch Header="Show LLM Thinking in App" IsOn="{Binding ShowThinkingInApp, Mode=TwoWay}" />
                                <Button Command="{Binding SaveSystemSettingsCommand}" HorizontalAlignment="Left">Save Gateway Settings</Button>
                                <TextBlock Text="{Binding TelegramGatewayLogsText}" Style="{StaticResource MetaTextStyle}" FontFamily="Cascadia Code" TextWrapping="WrapWholeWords" MaxLines="6" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="DATABASE MAINTENANCE" Style="{StaticResource PanelTitleStyle}" FontSize="18" Margin="0,12,0,0" />
                        <Border Padding="14" CornerRadius="8" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Active Database:" Style="{StaticResource MetaTextStyle}" />
                                <TextBlock Text="{Binding DatabasePathDisplay}" FontSize="12" TextWrapping="Wrap" FontFamily="Cascadia Code" />
                                
                                <Grid ColumnSpacing="12" Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Database Size" Style="{StaticResource MetaTextStyle}" />
                                        <TextBlock Text="{Binding DatabaseSizeDisplay}" FontSize="16" FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Integrity Check Status" Style="{StaticResource MetaTextStyle}" />
                                        <TextBlock Text="{Binding DatabaseIntegrityDisplay}" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ArgusAccentBrush}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                                    <Button Content="Run Integrity Check" Command="{Binding RunIntegrityCheckCommand}" />
                                </StackPanel>

                                <Border BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,1,0,0" Padding="0,10,0,0" Margin="0,6,0,0">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="BACKUPS" Style="{StaticResource PanelTitleStyle}" FontSize="14" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Header="Custom Backup Suffix" PlaceholderText="e.g. manual" Text="{Binding CustomBackupName, Mode=TwoWay}" />
                                            <Button Content="Create Backup" Command="{Binding CreateManualBackupCommand}" VerticalAlignment="Bottom" Grid.Column="1" />
                                        </Grid>
                                        
                                        <TextBlock Text="Available Local Backups" Style="{StaticResource MetaTextStyle}" Margin="0,6,0,0" />
                                        <ListView ItemsSource="{Binding BackupsCollection}" SelectionMode="None" MaxHeight="220" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1" CornerRadius="4">
                                            <ListView.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Padding="8,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding FileName}" FontSize="12" FontWeight="SemiBold" TextWrapping="NoWrap" />
                                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                                <TextBlock Text="{Binding CreatedAt, Converter={StaticResource DateTimeOffsetToStringConverter}}" FontSize="10" Style="{StaticResource MetaTextStyle}" />
                                                                <TextBlock Text="{Binding SizeDisplay}" FontSize="10" Style="{StaticResource MetaTextStyle}" />
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" ToolTipService.ToolTip="Restore this backup" Command="{Binding DataContext.RestoreBackupCommand, ElementName=RootPage}" CommandParameter="{Binding}" Margin="0,0,4,0" Padding="6">
                                                            <FontIcon Glyph="&#xE777;" FontSize="12" />
                                                        </Button>
                                                        <Button Grid.Column="2" ToolTipService.ToolTip="Delete backup" Command="{Binding DataContext.DeleteBackupCommand, ElementName=RootPage}" CommandParameter="{Binding}" Background="#33FF4F5A" Foreground="#FFFF4F5A" BorderBrush="#88FF4F5A" Padding="6">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListView.ItemTemplate>
                                        </ListView>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Border Grid.Column="2" Grid.Row="1" Grid.RowSpan="2" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1,0,0,0"
            Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=!Dashboard}">
            <ScrollViewer Padding="18">
                <StackPanel Spacing="14">
                    <TextBlock Text="INSPECTOR" Style="{StaticResource PanelTitleStyle}" />
                    <StackPanel Visibility="{Binding SelectedNode, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="Node" Style="{StaticResource MetaTextStyle}" />
                        <TextBox Text="{Binding SelectedNode.Title, Mode=TwoWay}" FontSize="16" FontWeight="SemiBold" />
                        <TextBox Text="{Binding SelectedNode.Summary, Mode=TwoWay}" TextWrapping="Wrap" />
                        <TextBlock Text="Type" Style="{StaticResource MetaTextStyle}" Margin="0,4,0,0" />
                        <ComboBox ItemsSource="{Binding NodeTypes}" SelectedItem="{Binding SelectedNode.Type, Mode=TwoWay}" />
                        <Button Command="{Binding SaveNodeCommand}" Margin="0,8,0,0">Save Node</Button>
                    </StackPanel>
                    <TextBlock Text="Project Context" Style="{StaticResource PanelTitleStyle}" FontSize="15" />
                    <TextBlock Text="{Binding ProjectContextText}" Style="{StaticResource MetaTextStyle}" TextWrapping="WrapWholeWords" />
                    <StackPanel Spacing="8" Visibility="{Binding CurrentView, Converter={StaticResource ViewVisibilityConverter}, ConverterParameter=Graph}">
                        <TextBlock Text="MOST CONNECTED" Style="{StaticResource PanelTitleStyle}" FontSize="15" Margin="0,8,0,0" />
                        <ListView ItemsSource="{Binding Dashboard.MostConnectedNodes}" SelectedItem="{Binding SelectedNode, Mode=TwoWay}" Style="{StaticResource DashboardListViewStyle}" MaxHeight="220">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" Margin="0,4" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Grid.Row="2" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="0,1,0,0"
            Visibility="{Binding BottomChatVisibility}">
            <Grid Padding="18,12" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ListView x:Name="BottomChatList" ItemsSource="{Binding ChatMessages}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <!-- Standard message -->
                                <StackPanel Visibility="{Binding Role, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=message}">
                                    <TextBlock Text="{Binding Role}" FontSize="10" Foreground="{StaticResource ArgusMutedTextBrush}" FontFamily="Cascadia Code" />
                                    <Border Padding="10,8" CornerRadius="8" Background="{StaticResource PanelBrush}">
                                        <TextBlock Text="{Binding Content}" TextWrapping="WrapWholeWords" Foreground="{StaticResource ArgusTextBrush}" FontSize="12" />
                                    </Border>
                                </StackPanel>

                                <!-- Thinking process -->
                                <StackPanel Visibility="{Binding Role, Converter={StaticResource RoleVisibilityConverter}, ConverterParameter=thinking}">
                                    <Expander HorizontalAlignment="Stretch" Margin="0,4" ExpandDirection="Down" IsExpanded="{Binding IsExpanded, Mode=TwoWay}">
                                        <Expander.Header>
                                            <Grid ColumnSpacing="8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <ProgressRing IsActive="{Binding Content, Converter={StaticResource ThinkingActiveConverter}}"
                                                              Visibility="{Binding Content, Converter={StaticResource ThinkingActiveVisibilityConverter}}"
                                                              Width="14" Height="14" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Content, Converter={StaticResource ThinkingHeaderConverter}}"
                                                           FontWeight="SemiBold" FontSize="11" Foreground="{StaticResource ArgusMutedTextBrush}" VerticalAlignment="Center" />
                                            </Grid>
                                        </Expander.Header>
                                        <TextBlock Text="{Binding Content, Converter={StaticResource ThinkingBodyConverter}}"
                                                   TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource ArgusMutedTextBrush}" Padding="8,4" />
                                    </Expander>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <Grid Grid.Row="1" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInputBox" PlaceholderText="Ask Argus anything..." Text="{Binding ChatInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" KeyDown="ChatInputBox_OnKeyDown" />
                    <Button Grid.Column="1" Command="{Binding SendChatCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE725;" FontSize="14" />
                            <TextBlock Text="Send" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3" Padding="12,0" Background="#CC080D18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StatusText}" Style="{StaticResource MetaTextStyle}" FontSize="11" VerticalAlignment="Center" MaxLines="1" TextTrimming="CharacterEllipsis" />
            <Button Grid.Column="1" Padding="6,2" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" CornerRadius="4"
                    ToolTipService.ToolTip="{Binding ContextTrackerDetailText}">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="5">
                        <TextBlock Text="CTX" Style="{StaticResource MetaTextStyle}" FontSize="9" />
                        <TextBlock Text="{Binding ContextTrackerText}" Style="{StaticResource MetaTextStyle}" FontSize="11" />
                        <TextBlock Text="{Binding ContextTrackerPercentText}" Style="{StaticResource MetaTextStyle}" FontSize="9" />
                    </StackPanel>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="Top">
                        <StackPanel Width="280" Spacing="8" Padding="4">
                            <TextBlock Text="CONTEXT USAGE" Style="{StaticResource PanelTitleStyle}" FontSize="12" />
                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ContextTrackerPercent}" />
                            <TextBlock Text="{Binding ContextTrackerText}" FontFamily="Cascadia Code" FontSize="13" />
                            <TextBlock Text="{Binding ContextTrackerDetailText}" Style="{StaticResource MetaTextStyle}" TextWrapping="WrapWholeWords" />
                            <TextBlock Text="{Binding ContextBreakdownText}" Style="{StaticResource MetaTextStyle}" FontSize="10" TextWrapping="WrapWholeWords"
                                       Visibility="{Binding ContextBreakdownText, Converter={StaticResource EmptyStringToVisibilityConverter}}" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button Grid.Column="2" Padding="6,2" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" CornerRadius="4">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding SelectedModel}" Style="{StaticResource MetaTextStyle}" FontSize="11" />
                        <FontIcon Glyph="&#xE972;" FontSize="8" Foreground="{StaticResource ArgusMutedTextBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="Top">
                        <StackPanel Width="220" Spacing="10" Padding="4">
                            <TextBlock Text="MODEL CONFIGURATION" Style="{StaticResource PanelTitleStyle}" FontSize="12" Margin="0,0,0,4" />
                            <StackPanel Spacing="3">
                                <TextBlock Text="LLM service" Style="{StaticResource MetaTextStyle}" FontSize="10" />
                                <ComboBox ItemsSource="{Binding ProviderProfiles}" SelectedItem="{Binding SelectedProvider, Mode=TwoWay}" HorizontalAlignment="Stretch">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}" />
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Spacing="3">
                                <TextBlock Text="Model" Style="{StaticResource MetaTextStyle}" FontSize="10" />
                                <ComboBox ItemsSource="{Binding ModelOptions}" SelectedItem="{Binding SelectedModel, Mode=TwoWay}" HorizontalAlignment="Stretch" />
                            </StackPanel>
                            <StackPanel Spacing="8" Visibility="{Binding HasReasoningControls, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Height="1" Background="{StaticResource ArgusMutedBorderBrush}" Margin="0,4" />
                                <ToggleSwitch Header="Thinking Mode"
                                              IsOn="{Binding IsThinkingEnabled, Mode=TwoWay}"
                                              OffContent="Disabled"
                                              OnContent="Enabled"
                                              Visibility="{Binding CanToggleThinkingMode, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock Text="{Binding ReasoningCapabilityHelpText}"
                                           Style="{StaticResource MetaTextStyle}"
                                           FontSize="10"
                                           TextWrapping="WrapWholeWords" />
                                <StackPanel Spacing="4" Visibility="{Binding ShowReasoningEffortPicker, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Reasoning Effort" Style="{StaticResource MetaTextStyle}" FontSize="10" />
                                    <ComboBox ItemsSource="{Binding ReasoningEffortOptions}"
                                              SelectedItem="{Binding SelectedReasoningEffort, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch" />
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button Grid.Column="3" Padding="7,2" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" CornerRadius="4">
                <Button.Content>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Border Width="7" Height="7" CornerRadius="4" Background="{StaticResource ArgusAccentBrush}"
                                Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="{Binding UpdateButtonText}" Style="{StaticResource MetaTextStyle}" FontSize="11" />
                    </StackPanel>
                </Button.Content>
                <Button.Flyout>
                    <Flyout Placement="TopEdgeAlignedRight">
                        <StackPanel Width="320" Spacing="10" Padding="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ProgressRing Width="16" Height="16" IsActive="{Binding IsUpdateBusy}" />
                                <TextBlock Text="{Binding UpdateStatusText}" Style="{StaticResource PanelTitleStyle}" FontSize="13" />
                            </StackPanel>
                            <TextBlock Text="{Binding UpdateReleaseNotes}" Style="{StaticResource MetaTextStyle}"
                                       TextWrapping="WrapWholeWords" MaxHeight="180" />
                            <Button Content="Download and install" Command="{Binding InstallUpdateCommand}"
                                    Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BoolToVisibilityConverter}}"
                                    HorizontalAlignment="Stretch" />
                            <Button Content="Check again" Command="{Binding CheckForUpdatesCommand}"
                                    HorizontalAlignment="Stretch" />
                            <HyperlinkButton Content="View releases" NavigateUri="https://github.com/Guts444/argus-agent/releases"
                                             HorizontalAlignment="Center" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <Border x:Name="CommandPaletteOverlay" Grid.RowSpan="3" Grid.ColumnSpan="3" Background="#88000000" Visibility="{Binding IsCommandPaletteOpen, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,120,0,0" Width="500" Padding="16" CornerRadius="12" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource ArgusMutedBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <TextBox x:Name="CommandPaletteBox" PlaceholderText="Type a command or search..." Text="{Binding CommandPaletteQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" KeyDown="CommandPaletteBox_OnKeyDown" />
                    <ListView x:Name="CommandPaletteList" ItemsSource="{Binding CommandPaletteItems}" SelectedItem="{Binding SelectedCommandPaletteItem, Mode=TwoWay}" MaxHeight="300" ItemClick="CommandPaletteList_OnItemClick" IsItemClickEnabled="True">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Padding="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Padding="4,2" CornerRadius="4" Background="#1A00F0FF">
                                        <TextBlock Text="{Binding Category}" FontSize="10" Foreground="#FF00F0FF" />
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Foreground="{StaticResource ArgusTextBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
